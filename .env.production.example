APP_NAME="ERAH Plateforme"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_TIMEZONE=Europe/Paris
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=erah
DB_USERNAME=erah
DB_PASSWORD=change-me

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=contact@example.com
MAIL_FROM_NAME="${APP_NAME}"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
ASSISTANT_ENABLED=true
ASSISTANT_PROVIDER=none
ASSISTANT_MODEL=gpt-4.1-mini
ASSISTANT_BASE_URL=https://api.openai.com/v1
ASSISTANT_API_KEY=
ASSISTANT_TIMEOUT=45
ASSISTANT_TEMPERATURE=0.45
ASSISTANT_MAX_TOKENS=900
ASSISTANT_PERSONALIZATION_ENABLED=true
ASSISTANT_MEMORY_ENABLED=true
ASSISTANT_MEMORY_WINDOW=12
ASSISTANT_STREAMING_ENABLED=true
ASSISTANT_STREAM_SIMULATED_DELAY_MS=16
ASSISTANT_FALLBACK_ENABLED=true
ASSISTANT_KNOWLEDGE_ARTICLE_LIMIT=8
ASSISTANT_KNOWLEDGE_GLOSSARY_LIMIT=8
ASSISTANT_CONVERSATION_LIMIT=24

SANCTUM_STATEFUL_DOMAINS=example.com,www.example.com
